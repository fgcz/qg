"""Test data workflow for queue generator validation.

Complete pipeline:
1. Extract SLD files from zip
2. Convert SLD → CSV (sld_to_csv.py)
3. Generate queue params JSON (csv_to_params.py)
4. Run queue generator
5. Compare generated vs original (compare_queues.py)
6. Output: results/test_results.csv

Usage:
    snakemake -j4 all        Run complete pipeline
    snakemake results_app    Launch results viewer
    snakemake clean_all      Remove all intermediates
"""

import json
from pathlib import Path

# Directories
REFERENCE_DIR = Path("reference")
PARAMS_DIR = Path("params_json")
GENERATED_DIR = Path("generated")
RESULTS_DIR = Path("results")
TOOLS_DIR = Path("tools")

INSTRUMENTS = ["astral", "ascend", "lumos2", "exploris2"]


# =============================================================================
# Helper Functions
# =============================================================================

def get_original_csv(instrument, name):
    """Get path to original CSV from param name."""
    config_path = Path(f"params_json/{instrument}/{name}.json")
    if config_path.exists():
        with open(config_path) as f:
            config = json.load(f)
            source_file = config.get("_source_file", f"{name}.csv")
            return str(REFERENCE_DIR / "csv" / instrument / source_file)
    return str(REFERENCE_DIR / "csv" / instrument / f"{name}.csv")


def get_all_params(_wildcards):
    """Get all param files from all instruments after checkpoint completes."""
    checkpoints.params.get()
    all_params = []
    for instrument in INSTRUMENTS:
        params_dir = Path(f"params_json/{instrument}")
        if params_dir.exists():
            all_params.extend([str(f) for f in params_dir.glob("*.json")])
    return all_params


def get_comparison_results(_wildcards):
    """Get comparison result files from all instruments after params are generated."""
    checkpoints.params.get()
    results = []
    for instrument in INSTRUMENTS:
        params_dir = Path(f"params_json/{instrument}")
        if params_dir.exists():
            results.extend([f"results/{instrument}/{f.stem}.json" for f in params_dir.glob("*.json")])
    return results


# =============================================================================
# Main Targets
# =============================================================================

rule all:
    """Run complete pipeline: extract → convert → params → generate → compare."""
    input:
        "results/test_results.csv"


rule help:
    """Show available targets."""
    run:
        print("""
Test Data Workflow - Queue Generator Validation

Pipeline:
  1. extract      Extract SLD files from zip archives
  2. sld_to_csv   Convert SLD → CSV
  3. params       Generate queue params JSON
  4. generate     Run queue generator
  5. compare      Compare generated vs original
  6. summary      Create test_results.csv

Targets:
  all                   Run complete pipeline
  marimo_orig_qgen      Compare original vs generated queues
  marimo_queue_analysis Analyze queue patterns
  clean                 Remove generated/ and results/
  clean_all             Remove ALL intermediates (keep only reference/sld/)

Usage:
  snakemake -j4 all              # Run full pipeline
  snakemake marimo_orig_qgen     # View results in marimo
  snakemake clean_all            # Start fresh
""")


# =============================================================================
# Phase 0: Extract SLD from Zip
# =============================================================================

rule extract:
    """Extract SLD files from zip archives in reference/zip/ to reference/sld/."""
    output:
        directory("reference/sld")
    shell:
        """
        mkdir -p reference/sld
        for zip in reference/zip/*.zip; do
            if [ -f "$zip" ]; then
                instrument=$(basename "$zip" .zip)
                mkdir -p "reference/sld/$instrument"
                unzip -o -j "$zip" -d "reference/sld/$instrument" '*.sld' 2>/dev/null || true
                echo "Extracted: $zip → reference/sld/$instrument/"
            fi
        done
        """


# =============================================================================
# Phase 1: SLD → CSV Conversion
# =============================================================================

rule sld_to_csv:
    """Convert all SLD files to CSV."""
    input:
        expand("reference/csv/{instrument}", instrument=INSTRUMENTS),
        "reference/merged.csv"


rule convert_sld:
    """Parse all SLD files in an instrument directory to CSV."""
    input:
        sld_dir="reference/sld/{instrument}"
    output:
        csv_dir=directory("reference/csv/{instrument}")
    log:
        "reference/csv/{instrument}.log"
    shell:
        "qg-tools sld-to-csv {input.sld_dir} --output-dir {output.csv_dir} --check --sanitize --log-file {log}"


rule merge_csvs:
    """Merge all CSVs into single file for analysis."""
    input:
        csv_dirs=expand("reference/csv/{instrument}", instrument=INSTRUMENTS)
    output:
        "reference/merged.csv"
    shell:
        "qg-tools merge reference/csv --output {output}"


# =============================================================================
# Phase 2: CSV → Param JSON Generation
# =============================================================================

checkpoint params:
    """Generate param JSONs from reference CSVs."""
    input:
        csv_dirs=expand("reference/csv/{instrument}", instrument=INSTRUMENTS)
    output:
        directory("params_json")
    shell:
        """
        mkdir -p params_json/astral params_json/ascend params_json/lumos2 params_json/exploris2
        qg-tools csv-to-params reference/csv/astral/ -o params_json/astral/
        qg-tools csv-to-params reference/csv/ascend/ -o params_json/ascend/
        qg-tools csv-to-params reference/csv/lumos2/ -o params_json/lumos2/
        qg-tools csv-to-params reference/csv/exploris2/ -o params_json/exploris2/
        """


# =============================================================================
# Phase 3: Queue Generator Testing
# =============================================================================

rule test:
    """Run test pipeline (generate, compare, summarize)."""
    input:
        "results/test_results.csv"


rule generate_queue:
    """Run queue generator on a param file."""
    input:
        params="params_json/{instrument}/{name}.json"
    output:
        csv="generated/{instrument}/{name}.csv"
    shell:
        """
        cd .. && qg test_data/{input.params} -o test_data/{output.csv} 2>/dev/null || touch test_data/{output.csv}
        """


rule compare:
    """Compare generated queue CSV with original reference CSV."""
    input:
        generated="generated/{instrument}/{name}.csv",
        config="params_json/{instrument}/{name}.json"
    output:
        result="results/{instrument}/{name}.json"
    params:
        original=lambda wildcards: get_original_csv(wildcards.instrument, wildcards.name)
    shell:
        """
        qg-tools compare {input.generated} {params.original} {input.config} {output.result}
        """


rule summary:
    """Aggregate comparison results into test_results.csv database."""
    input:
        get_comparison_results
    output:
        "results/test_results.csv"
    shell:
        "qg-tools summarize {output} {input}"


# =============================================================================
# Analysis Apps
# =============================================================================

rule marimo_orig_qgen:
    """Launch test results marimo app (compare original vs generated)."""
    input:
        "results/test_results.csv"
    shell:
        "marimo run ../src/qg/tools_apps/compare_existing_generated.py"


rule marimo_queue_analysis:
    """Launch queue analysis marimo app."""
    input:
        "reference/merged.csv"
    shell:
        "marimo run ../src/qg/tools_apps/queue_analysis_marimo.py"


# =============================================================================
# Cleanup
# =============================================================================

rule clean:
    """Remove generated/ and results/ (keeps reference data and params)."""
    shell:
        """
        rm -rf generated/ results/
        echo "Cleaned generated/ and results/"
        """


rule clean_all:
    """Remove ALL intermediates, keep only reference/sld/ and reference/zip/."""
    shell:
        """
        rm -rf generated/ results/ params_json/ reference/csv/ reference/merged.csv
        echo "Cleaned all intermediates. Only reference/sld/ and reference/zip/ preserved."
        """
