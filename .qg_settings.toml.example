# GitLab settings for config review workflow.
# Copy this file to .qg_settings.toml and fill in your credentials.
# IMPORTANT: .qg_settings.toml is gitignored — never commit your token.

[gitlab]
url = "https://gitlab.example.com"
project = "your-group/your-project"
# Token needs scope: api (or write_repository + read_api)
private_token = "glpat-xxxxxxxxxxxxxxxxxxxx"
