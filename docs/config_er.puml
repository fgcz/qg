@startuml config_er
!theme plain
title Queue Generation Configuration - Entity Relationship Diagram

' Legend: Config file locations
note as FileLocations
  **Config File Locations**
  ----
  instruments.csv -> Instrument
  instrument_patterns.csv -> Instrument Pattern
  combinations.csv -> Combination
  sampler.toml -> Sampler, Container
  samples.csv -> Sample
  queue_patterns.toml -> Queue Pattern
  qc_layouts.toml -> QC Layout
  output_formats.toml -> Output Format
  methods/<tech>/<instr>_methods.csv -> Methods
end note

' Entities
entity "Technology" as tech {
  * technology_id : string
  --
  proteomics | metabolomics | lipidomics
}

entity "Instrument" as instr <<instruments.csv>> {
  * technology : PK (part)
  * instrument : PK (part)
  --
  methods_file : string
}

entity "Instrument Pattern" as instr_pattern <<instrument_patterns.csv>> {
  * technology : FK
  * instrument : FK
  * pattern : FK
  --
  is_default : boolean
}

entity "Sampler" as sampler <<sampler.toml>> {
  * sampler_id : PK
  --
  description : string
  plates[] : string
  qc_plate : string
  --
  // Evosep only
  slots[] : int
  positions_per_slot : int
}

entity "Sampler.Container" as container <<sampler.toml>> {
  * sampler_id.container : PK
  --
  container_type : Vial | Plate
  position_source : generated | input
  fill_order : row_major | sequential
  position_format : string
  sample_rows[] : string
  qc_row : string
  cols[] : int
  samples_per_plate : int
}

entity "Output Format" as outfmt <<output_formats.toml>> {
  * format_id : PK
  --
  description : string
  file_extension : string
  columns : map<string, string>
}

entity "Combination" as combo <<combinations.csv>> {
  * instrument_id : FK
  * sampler.container : FK
  * output_format : FK
  --
  position_format : string (optional)
  ----
  Valid instrument+sampler+format tuple
}

entity "Queue Pattern" as pattern <<queue_patterns.toml>> {
  * technology.pattern_id : PK
  --
  description : string
  run_QC_after_n_samples : int
  start[] : FK -> Sample
  middle[] : FK -> Sample
  end[] : FK -> Sample
  middle_extended[] : FK -> Sample
  separation[] : FK -> Sample (optional)
}

entity "Sample" as sample <<samples.csv>> {
  * technology : PK (part)
  * sample_id : PK (part)
  --
  sample_name : string
  description : string
  inj_vol : float
  file_name_template : string
}

entity "QC Layout" as qclayout <<qc_layouts.toml>> {
  * technology.sampler_key : PK
  --
  // Key derived from sampler path:
  // Try "Sampler.container" first,
  // fall back to "Sampler"
  --
  // Well-plate samplers
  sample_id : position_string
  --
  // Tip-plate samplers
  sample_id : {tray, pos_start, pos_end}
}

entity "Methods File" as methods <<methods/*.csv>> {
  * methods/<tech>/<instr>_methods.csv
  --
  sample_type : string
  polarity : string (pos|neg|empty)
  method_name : string
  method_path : string
}

' Relationships
tech ||--o{ instr : "has"
tech ||--o{ pattern : "has"
tech ||--o{ sample : "has"
tech ||--o{ qclayout : "has"
tech ||--o{ methods : "has (via path)"

sampler ||--|{ container : "contains"
container }o--|| qclayout : "derived key lookup"

instr ||--o{ instr_pattern : "has"
instr_pattern }o--|| pattern : "references"
instr ||--|| methods : "methods_file"

pattern }o--o{ sample : "start/middle/end"
qclayout }o--o{ sample : "positions"
methods }o--o{ sample : "sample_type"

combo }o--|| instr : "instrument"
combo }o--|| container : "sampler.container"
combo }o--|| outfmt : "output_format"

@enduml
